generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                @id @default(cuid())
  username              String                @unique
  password              String
  email                 String?               @unique
  firstName             String
  lastName              String
  phoneNumber           String?
  address               String?
  userType              UserType
  isActive              Boolean               @default(true)
  dateOfBirth           DateTime?
  governmentId          String?               @unique
  idType                String?
  barangayResidence     String?
  occupation            String?
  emergencyContact      String?
  emergencyContactPhone String?
  reasonForRegistration String?
  assignedVehicleId     String?               @unique
  assignedVehicleAssignedAt DateTime?
  assignedVehicleAssignedBy String?
  isVerified            Boolean               @default(false)
  verificationToken     String?
  verificationExpiry    DateTime?
  verifiedAt            DateTime?
  verifiedBy            String?
  registrationIp        String?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  loginAttempts         Int                   @default(0)
  lockedUntil           DateTime?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  passwordResetOtp      String?
  passwordResetOtpExpiry DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  fareCalculations      FareCalculation[]
  handledIncidents      Incident[]            @relation("HandledBy")
  reportedIncidents     Incident[]            @relation("ReportedBy")
  uploadedEvidence      Evidence[]            @relation("EvidenceUploader")
  reviewedEvidence      Evidence[]            @relation("EvidenceReviewer")
  verificationLogs      UserVerificationLog[]
  discountCard          DiscountCard?
  createdLocations      Location[]            @relation("LocationCreator")
  verifiedLocations     Location[]            @relation("LocationVerifier")
  createdFareRateVersions FareRateVersion[]   @relation("FareRateVersionCreator")
  canceledFareRateVersions FareRateVersion[]  @relation("FareRateVersionCanceller")
  createdAnnouncements  Announcement[]        @relation("AnnouncementCreator")
  updatedAnnouncements  Announcement[]        @relation("AnnouncementUpdater")
  archivedAnnouncements Announcement[]        @relation("AnnouncementArchiver")
  updatedRoutingSettings RoutingSettings[]    @relation("RoutingSettingsUpdater")
  routingSettingsAuditEntries RoutingSettingsAudit[] @relation("RoutingSettingsAuditActor")
  permitQrAuditEntries  PermitQrAudit[]       @relation("PermitQrAuditActor")
  fareRateDeletionAuditEntries FareRateDeletionAudit[] @relation("FareRateDeletionAuditActor")
  verifiedIncidents     Incident[]            @relation("IncidentEvidenceVerifier")
  ticketIssuedIncidents Incident[]            @relation("IncidentTicketIssuer")
  dismissedIncidents    Incident[]            @relation("IncidentDismisser")
  paymentRecordedIncidents Incident[]         @relation("IncidentPaymentRecorder")
  assignedVehicle       Vehicle?              @relation("DriverAssignedVehicle", fields: [assignedVehicleId], references: [id])
  driverAssignmentHistory DriverVehicleAssignmentHistory[] @relation("DriverAssignmentHistoryUser")
  driverTripSessions    VehicleTripSession[]  @relation("DriverTripSessions")
  riderTripSessionEntries VehicleTripSessionRider[] @relation("RiderTripSessionEntries")
  driverTripSessionEvents VehicleTripSessionRiderEvent[] @relation("DriverTripSessionEvents")

  @@index([username])
  @@index([userType])
  @@index([isActive])
  @@index([isVerified])
  @@index([createdAt])
  @@index([userType, isActive])
  @@map("users")
}

model FareRateVersion {
  id                 String    @id @default(cuid())
  baseFare           Decimal   @db.Decimal(10, 2)
  perKmRate          Decimal   @db.Decimal(10, 2)
  effectiveAt        DateTime
  createdAt          DateTime  @default(now())
  createdBy          String?
  notes              String
  canceledAt         DateTime?
  canceledBy         String?
  cancellationReason String?
  createdByUser      User?     @relation("FareRateVersionCreator", fields: [createdBy], references: [id])
  canceledByUser     User?     @relation("FareRateVersionCanceller", fields: [canceledBy], references: [id])

  @@index([effectiveAt])
  @@index([createdAt])
  @@index([canceledAt])
  @@index([effectiveAt, canceledAt])
  @@map("fare_rate_versions")
}

model FareRateDeletionAudit {
  id                String   @id @default(cuid())
  fareRateVersionId String
  action            String
  reason            String?
  deletedAt         DateTime @default(now())
  deletedBy         String?
  deletedByUser     User?    @relation("FareRateDeletionAuditActor", fields: [deletedBy], references: [id])

  @@index([fareRateVersionId, deletedAt])
  @@index([deletedAt])
  @@map("fare_rate_deletion_audit")
}

model RoutingSettings {
  id              String                 @id @default("global")
  primaryProvider RoutingProviderSetting @default(ORS)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  updatedBy       String?
  updatedByUser   User?                  @relation("RoutingSettingsUpdater", fields: [updatedBy], references: [id])
  auditEntries    RoutingSettingsAudit[]

  @@index([updatedAt])
  @@map("routing_settings")
}

model RoutingSettingsAudit {
  id                     String                  @id @default(cuid())
  routingSettingsId      String
  previousPrimaryProvider RoutingProviderSetting?
  newPrimaryProvider     RoutingProviderSetting
  changedAt              DateTime                @default(now())
  changedBy              String?
  routingSettings        RoutingSettings         @relation(fields: [routingSettingsId], references: [id], onDelete: Cascade)
  changedByUser          User?                   @relation("RoutingSettingsAuditActor", fields: [changedBy], references: [id])

  @@index([routingSettingsId, changedAt])
  @@index([changedAt])
  @@map("routing_settings_audit")
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  body           String
  category       AnnouncementCategory
  startsAt       DateTime
  endsAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  createdBy      String
  updatedBy      String
  archivedAt     DateTime?
  archivedBy     String?
  createdByUser  User                 @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  updatedByUser  User                 @relation("AnnouncementUpdater", fields: [updatedBy], references: [id])
  archivedByUser User?                @relation("AnnouncementArchiver", fields: [archivedBy], references: [id])

  @@index([archivedAt, startsAt, createdAt])
  @@index([archivedAt, endsAt])
  @@map("announcements")
}

model Vehicle {
  id                 String            @id @default(cuid())
  plateNumber        String            @unique
  vehicleType        VehicleType
  make               String
  model              String
  year               Int
  color              String
  capacity           Int
  ownerName          String
  ownerContact       String
  driverName         String?
  driverLicense      String?
  isActive           Boolean           @default(true)
  registrationExpiry DateTime
  insuranceExpiry    DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  fareCalculations   FareCalculation[]
  incidents          Incident[]
  permit             Permit?
  assignedDriver     User?             @relation("DriverAssignedVehicle")
  driverAssignmentHistory DriverVehicleAssignmentHistory[] @relation("DriverAssignmentHistoryVehicle")
  tripSessions       VehicleTripSession[]

  @@index([plateNumber])
  @@index([vehicleType])
  @@index([isActive])
  @@index([ownerName])
  @@index([vehicleType, isActive])
  @@map("vehicles")
}

model Incident {
  id            String         @id @default(cuid())
  incidentType  IncidentType
  description   String
  location      String
  coordinates   String?
  fareCalculationId String?
  tripOrigin    String?
  tripDestination String?
  tripFare      Decimal?
  tripDiscountType DiscountType?
  tripCalculatedAt DateTime?
  tripCalculationType String?
  tripVehicleType VehicleType?
  tripPermitPlateNumber String?
  tripPlateNumber String?
  reportedById  String
  handledById   String?
  vehicleId     String?
  vehicleType   VehicleType?
  driverLicense String?
  plateNumber   String?
  status        IncidentStatus @default(PENDING)
  penaltyAmount Decimal?
  offenseNumberAtIssuance Int?
  offenseTierAtIssuance OffenseTier?
  penaltyRuleVersion String?  
  paymentStatus TicketPaymentStatus @default(NOT_APPLICABLE)
  paidAt        DateTime?
  officialReceiptNumber String? @unique
  remarks       String?
  ticketNumber  String?        @unique
  incidentDate  DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  resolvedAt    DateTime?

  // Evidence verification audit
  evidenceVerifiedAt   DateTime?
  evidenceVerifiedById String?

  // Ticket issuance audit
  ticketIssuedAt   DateTime?
  ticketIssuedById String?

  // Dismissal audit
  dismissedAt    DateTime?
  dismissedById  String?
  dismissRemarks String?

  // Payment recording audit
  paymentRecordedAt   DateTime?
  paymentRecordedById String?

  fareCalculation FareCalculation? @relation(fields: [fareCalculationId], references: [id])
  handledBy       User?            @relation("HandledBy", fields: [handledById], references: [id])
  reportedBy      User             @relation("ReportedBy", fields: [reportedById], references: [id])
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id])
  evidence        Evidence[]
  evidenceVerifiedBy   User?        @relation("IncidentEvidenceVerifier", fields: [evidenceVerifiedById], references: [id])
  ticketIssuedBy       User?        @relation("IncidentTicketIssuer", fields: [ticketIssuedById], references: [id])
  dismissedBy          User?        @relation("IncidentDismisser", fields: [dismissedById], references: [id])
  paymentRecordedBy    User?        @relation("IncidentPaymentRecorder", fields: [paymentRecordedById], references: [id])

  @@index([fareCalculationId])
  @@index([status])
  @@index([incidentType])
  @@index([reportedById])
  @@index([handledById])
  @@index([plateNumber])
  @@index([incidentDate])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([status, incidentType])
  @@index([status, createdAt])
  @@index([status, paymentStatus])
  @@index([evidenceVerifiedById])
  @@index([ticketIssuedById])
  @@index([dismissedById])
  @@index([paymentRecordedById])
  @@map("incidents")
}

model Evidence {
  id          String        @id @default(cuid())
  incidentId  String
  fileName    String
  fileUrl     String
  fileType    EvidenceType
  fileSize    Int?
  uploadedBy  String
  status      EvidenceStatus @default(PENDING_REVIEW)
  storageStatus EvidenceStorageStatus @default(AVAILABLE)
  fileDeletedAt DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?
  remarks     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  incident    Incident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploader    User          @relation("EvidenceUploader", fields: [uploadedBy], references: [id])
  reviewer    User?         @relation("EvidenceReviewer", fields: [reviewedBy], references: [id])

  @@index([incidentId])
  @@index([status])
  @@index([uploadedBy])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("evidence")
}

model FareCalculation {
  id              String            @id @default(cuid())
  userId          String?
  vehicleId       String?
  fromLocation    String
  toLocation      String
  distance        Decimal
  calculatedFare  Decimal
  actualFare      Decimal?
  calculationType String
  routeData       String?
  discountCardId  String?
  originalFare    Decimal?
  discountApplied Decimal?
  discountType    DiscountType?
  createdAt       DateTime          @default(now())
  incidents       Incident[]
  user            User?             @relation(fields: [userId], references: [id])
  vehicle         Vehicle?          @relation(fields: [vehicleId], references: [id])
  discountCard    DiscountCard?     @relation("DiscountedCalculations", fields: [discountCardId], references: [id])
  sessionRider    VehicleTripSessionRider? @relation("FareCalculationSessionRider")
  usageLog        DiscountUsageLog?

  @@index([userId])
  @@index([vehicleId])
  @@index([createdAt])
  @@index([calculationType])
  @@index([discountCardId])
  @@map("fare_calculations")
}

model VehicleTripSession {
  id         String                   @id @default(cuid())
  vehicleId  String
  driverUserId String
  status     DriverTripSessionStatus  @default(OPEN)
  openedAt   DateTime                 @default(now())
  closedAt   DateTime?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  vehicle    Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverUser User                     @relation("DriverTripSessions", fields: [driverUserId], references: [id], onDelete: Cascade)
  riders     VehicleTripSessionRider[]

  @@index([vehicleId, status])
  @@index([driverUserId, status])
  @@index([openedAt])
  @@map("vehicle_trip_sessions")
}

model VehicleTripSessionRider {
  id                   String                      @id @default(cuid())
  sessionId            String
    fareCalculationId    String?                     @unique
  riderUserId          String
    activeRequestKey     String?                     @unique
  status               DriverTripSessionRiderStatus @default(PENDING)
  originSnapshot       String
  destinationSnapshot  String
    distanceSnapshot     Decimal                     @db.Decimal(10, 2)
  fareSnapshot         Decimal                     @db.Decimal(10, 2)
    calculationTypeSnapshot String
    routeDataSnapshot    String?
    farePolicySnapshot   String?
    discountCardIdSnapshot String?
    originalFareSnapshot Decimal?                    @db.Decimal(10, 2)
    discountAppliedSnapshot Decimal?                 @db.Decimal(10, 2)
  discountTypeSnapshot DiscountType?
  joinedAt             DateTime                    @default(now())
    expiresAt            DateTime?
  acceptedAt           DateTime?
  boardedAt            DateTime?
  completedAt          DateTime?
  finalisedAt          DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  session              VehicleTripSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    fareCalculation      FareCalculation?            @relation("FareCalculationSessionRider", fields: [fareCalculationId], references: [id], onDelete: Cascade)
  riderUser            User                        @relation("RiderTripSessionEntries", fields: [riderUserId], references: [id], onDelete: Cascade)
  events               VehicleTripSessionRiderEvent[]

  @@index([sessionId, status])
  @@index([riderUserId, status])
    @@index([status, expiresAt])
  @@index([joinedAt])
  @@map("vehicle_trip_session_riders")
}

model VehicleTripSessionRiderEvent {
  id             String                      @id @default(cuid())
  sessionRiderId String
  action         DriverTripSessionRiderAction
  fromStatus     DriverTripSessionRiderStatus
  toStatus       DriverTripSessionRiderStatus
  actedByUserId  String
  createdAt      DateTime                    @default(now())
  sessionRider   VehicleTripSessionRider     @relation(fields: [sessionRiderId], references: [id], onDelete: Cascade)
  actedByUser    User                        @relation("DriverTripSessionEvents", fields: [actedByUserId], references: [id], onDelete: Cascade)

  @@index([sessionRiderId, createdAt])
  @@index([actedByUserId, createdAt])
  @@map("vehicle_trip_session_rider_events")
}

model Route {
  id          String   @id @default(cuid())
  name        String
  description String?
  waypoints   String
  distance    Decimal
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("routes")
}

model Location {
  id                    String              @id @default(cuid())
  name                  String              @unique
  type                  LocationType
  coordinates           String              // Format: "lat,lng"
  barangay              String?
  description           String?
  isActive              Boolean             @default(true)
  
  // Administrative fields
  createdBy             String
  createdByUser         User                @relation("LocationCreator", fields: [createdBy], references: [id])
  verifiedBy            String?
  verifiedByUser        User?               @relation("LocationVerifier", fields: [verifiedBy], references: [id])
  verifiedAt            DateTime?
  
  // Google Maps validation
  googlePlaceId         String?
  googleFormattedAddress String?
  lastValidated         DateTime?
  validationStatus      LocationValidationStatus @default(PENDING)
  
  // Boundary validation
  isWithinMunicipality  Boolean             @default(false)
  isWithinBarangay      Boolean             @default(false)
  actualBarangay        String?
  
  // Metadata
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  validationLogs        LocationValidation[]
  
  @@index([barangay])
  @@index([isActive])
  @@index([validationStatus])
  @@index([createdBy])
  @@map("locations")
}

model LocationValidation {
  id                    String   @id @default(cuid())
  locationId            String
  location              Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  validatedBy           String
  validationType        String   // "CREATION", "UPDATE", "PERIODIC_CHECK"
  
  // Validation results
  isValid               Boolean
  validationErrors      String[] // JSON array of error messages
  validationWarnings    String[] // JSON array of warning messages
  
  // Boundary check results
  withinMunicipality    Boolean
  withinBarangay        Boolean
  detectedBarangay      String?
  
  // Google Maps results
  googleMapsValid       Boolean?
  googlePlaceId         String?
  googleAddress         String?
  googleConfidence      String?  // "high", "medium", "low"
  
  // Coordinates at time of validation
  validatedCoordinates  String
  
  validatedAt           DateTime @default(now())
  
  @@index([locationId])
  @@index([validatedAt])
  @@map("location_validations")
}

model UserVerificationLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  performedBy String
  reason      String?
  evidence    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_verification_logs")
}

model AdminUserCreation {
  id            String    @id @default(cuid())
  requestedBy   String
  userType      UserType
  firstName     String
  lastName      String
  phoneNumber   String
  assignedVehicleId String?
  department    String?
  position      String?
  employeeId    String?
  notes         String?
  isActive      Boolean   @default(false)
  approvedBy    String?
  approvedAt    DateTime?
  createdUserId String?
  createdAt     DateTime  @default(now())

  @@map("admin_user_creations")
}

model DriverVehicleAssignmentHistory {
  id         String   @id @default(cuid())
  userId     String
  vehicleId  String
  assignedBy String?
  assignedAt DateTime @default(now())
  endedBy    String?
  endedAt    DateTime?
  reason     String?
  isActive   Boolean  @default(true)
  user       User     @relation("DriverAssignmentHistoryUser", fields: [userId], references: [id], onDelete: Cascade)
  vehicle    Vehicle  @relation("DriverAssignmentHistoryVehicle", fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId, assignedAt])
  @@index([vehicleId, assignedAt])
  @@index([isActive, assignedAt])
  @@map("driver_vehicle_assignment_history")
}

model Permit {
  id                 String       @id @default(cuid())
  vehicleId          String       @unique
  permitPlateNumber  String       @unique
  qrToken            String?      @unique
  qrIssuedAt         DateTime?
  qrIssuedBy         String?
  driverFullName     String
  vehicleType        VehicleType
  issuedDate         DateTime     @default(now())
  expiryDate         DateTime
  status             PermitStatus @default(ACTIVE)
  remarks            String?
  encodedBy          String
  encodedAt          DateTime     @default(now())
  lastUpdatedBy      String?
  lastUpdatedAt      DateTime?
  renewalHistory     PermitRenewal[]
  qrAuditEntries     PermitQrAudit[]
  vehicle            Vehicle      @relation(fields: [vehicleId], references: [id])
  
  @@index([status])
  @@index([vehicleType])
  @@index([permitPlateNumber])
  @@index([expiryDate])
  @@index([qrIssuedAt])
  @@index([status, vehicleType])
  @@map("permits")
}

model PermitQrAudit {
  id                       String              @id @default(cuid())
  permitId                 String
  permitPlateNumber        String
  action                   PermitQrAuditAction
  actedBy                  String?
  actedAt                  DateTime            @default(now())
  previousTokenFingerprint String?
  currentTokenFingerprint  String
  permit                   Permit              @relation(fields: [permitId], references: [id], onDelete: Cascade)
  actedByUser              User?               @relation("PermitQrAuditActor", fields: [actedBy], references: [id])

  @@index([permitId, actedAt])
  @@index([actedBy, actedAt])
  @@index([action, actedAt])
  @@map("permit_qr_audit")
}

model PermitRenewal {
  id            String   @id @default(cuid())
  permitId      String
  previousExpiry DateTime
  newExpiry      DateTime
  renewedBy     String
  renewedAt     DateTime @default(now())
  notes         String?
  permit        Permit   @relation(fields: [permitId], references: [id], onDelete: Cascade)
  
  @@map("permit_renewals")
}

  model TerminalUnlockSession {
    id             String   @id @default(cuid())
    userId         String
    tokenHash      String   @unique
    expiresAt      DateTime
    lastActivityAt DateTime
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@index([userId])
    @@index([expiresAt])
    @@index([lastActivityAt])
    @@map("terminal_unlock_sessions")
  }

  model QrScanAudit {
    id                 String            @id @default(cuid())
    scannerUserId      String?
    scannedAt          DateTime          @default(now())
    submittedToken     String
    matchedPermitId    String?
    resultType         QrScanResultType
    scanSource         QrScanSource
    disposition        ScanDisposition?

    @@index([scannerUserId, scannedAt])
    @@index([matchedPermitId, scannedAt])
    @@index([resultType, scannedAt])
    @@map("qr_scan_audit")
  }

enum UserType {
  ADMIN
  DATA_ENCODER
  ENFORCER
  DRIVER
  PUBLIC
}

enum RoutingProviderSetting {
  ORS
  GOOGLE_ROUTES
}

enum AnnouncementCategory {
  EMERGENCY_NOTICE
  ROAD_CLOSURE
  ROAD_WORK
  TRAFFIC_ADVISORY
}

enum VehicleType {
  JEEPNEY
  TRICYCLE
  HABAL_HABAL
  MULTICAB
  BUS
  VAN
}

enum IncidentType {
  FARE_OVERCHARGE
  FARE_UNDERCHARGE
  RECKLESS_DRIVING
  VEHICLE_VIOLATION
  ROUTE_VIOLATION
  OTHER
}

enum IncidentStatus {
  PENDING
  INVESTIGATING
  TICKET_ISSUED
  RESOLVED
  DISMISSED
}

enum DriverTripSessionStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum DriverTripSessionRiderStatus {
  PENDING
  ACCEPTED
  BOARDED
  COMPLETED
  REJECTED_NOT_HERE
  REJECTED_FULL
  REJECTED_WRONG_TRIP
  CANCELLED
  EXPIRED
}

enum DriverTripSessionRiderAction {
  ACCEPT
  BOARDED
  DROPPED_OFF
  NOT_HERE
  FULL
  WRONG_TRIP
  CANCELLED
  EXPIRE
}

enum OffenseTier {
  FIRST
  SECOND
  THIRD_PLUS
}

enum TicketPaymentStatus {
  NOT_APPLICABLE
  UNPAID
  PAID
}

enum LocationType {
  BARANGAY
  LANDMARK
  SITIO
  URBAN
  RURAL
}

enum LocationValidationStatus {
  PENDING
  VALIDATED
  FAILED
  NEEDS_REVIEW
}

enum PermitStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}

enum ComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  REVIEW_REQUIRED
}

enum ScanDisposition {
  CLEAR
  FLAGGED
  BLOCKED
}

enum QrScanResultType {
  MATCHED
  NOT_FOUND
  ERROR
  UNAUTHORIZED
}

enum QrScanSource {
  CAMERA
  MANUAL
}

enum PermitQrAuditAction {
  ISSUE_QR
  ROTATE_QR
}

enum EvidenceType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum EvidenceStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
  REQUIRES_ADDITIONAL
}

enum EvidenceStorageStatus {
  AVAILABLE
  DELETED
}

model DiscountCard {
  id                    String              @id @default(cuid())
  userId                String              @unique
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  discountType          DiscountType
  
  // Identification Details
  idNumber              String?             @unique
  idType                String?
  issuingAuthority      String?
  
  // Supporting Information
  fullName              String
  dateOfBirth           DateTime
  photoUrl              String?
  
  // Student-specific
  schoolName            String?
  schoolAddress         String?
  gradeLevel            String?
  schoolIdExpiry        DateTime?
  
  // PWD-specific
  disabilityType        String?
  pwdIdExpiry           DateTime?
  
  // Verification Status
  verificationStatus    VerificationStatus  @default(PENDING)
  verifiedBy            String?
  verifiedAt            DateTime?
  verificationNotes     String?
  rejectionReason       String?
  
  // Admin Override Feature
  isAdminOverride       Boolean             @default(false)
  overrideReason        String?
  overrideBy            String?
  overrideAt            DateTime?
  
  // Validity
  isActive              Boolean             @default(false)
  validFrom             DateTime
  validUntil            DateTime
  
  // Usage Tracking (Anti-abuse)
  lastUsedAt            DateTime?
  usageCount            Int                 @default(0)
  dailyUsageCount       Int                 @default(0)
  lastResetDate         DateTime?
  
  // Audit Trail
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  // Relations
  fareCalculations      FareCalculation[]   @relation("DiscountedCalculations")
  usageLogs             DiscountUsageLog[]
  
  @@index([userId])
  @@index([discountType])
  @@index([verificationStatus])
  @@index([isActive])
  @@index([validUntil])
  @@index([isAdminOverride])
  @@map("discount_cards")
}

model DiscountUsageLog {
  id                String          @id @default(cuid())
  discountCardId    String
  discountCard      DiscountCard    @relation(fields: [discountCardId], references: [id], onDelete: Cascade)
  
  fareCalculationId String          @unique
  fareCalculation   FareCalculation @relation(fields: [fareCalculationId], references: [id])
  
  originalFare      Decimal         @db.Decimal(10, 2)
  discountAmount    Decimal         @db.Decimal(10, 2)
  finalFare         Decimal         @db.Decimal(10, 2)
  discountRate      Decimal         @db.Decimal(5, 2)
  
  fromLocation      String
  toLocation        String
  distance          Decimal         @db.Decimal(10, 2)
  
  // Anti-fraud tracking
  usedAt            DateTime        @default(now())
  ipAddress         String?
  deviceFingerprint String?
  gpsCoordinates    String?
  
  // Flags for suspicious activity
  isSuspicious      Boolean         @default(false)
  suspiciousReason  String?
  reviewedBy        String?
  reviewedAt        DateTime?
  
  @@index([discountCardId, usedAt])
  @@index([usedAt])
  @@map("discount_usage_logs")
}

enum DiscountType {
  SENIOR_CITIZEN
  PWD
  STUDENT
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  EXPIRED
}
