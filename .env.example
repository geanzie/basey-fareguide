# Database
DATABASE_URL="your_neon_database_connection_string_here"
# Optional direct connection for Prisma migrations and other schema-changing CLI commands.
# Use the non-pooler Neon hostname here when available.
DIRECT_DATABASE_URL="your_neon_direct_database_connection_string_here"

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# JWT Secret for authentication
JWT_SECRET="your-jwt-secret-key-here"

# Session timeout configuration
# Absolute session lifetime in seconds (default: 8 hours)
NEXT_PUBLIC_AUTH_SESSION_MAX_AGE_SECONDS=28800
# Idle timeout in milliseconds before automatic logout (default: 2 hours)
NEXT_PUBLIC_AUTH_IDLE_TIMEOUT_MS=7200000
# How often the client revalidates the current session with the server (default: 1 minute)
NEXT_PUBLIC_AUTH_REVALIDATION_MS=60000

# Google Maps API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Never commit real API keys to version control
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Server-side key for Google geocoding operations
GOOGLE_MAPS_SERVER_API_KEY=your_server_side_api_key_here

# Optional dedicated server-side key for Google Routes fallback.
# Use this when you want a separate key for routes.googleapis.com.
# Do not apply HTTP referrer restrictions to this key because route calculation
# happens on the server, not directly in the browser.
GOOGLE_ROUTES_API_KEY=your_google_routes_server_api_key_here

# OpenRouteService timeout in milliseconds before GPS fallback is used
ROUTING_ORS_TIMEOUT_MS=3500

# Google Routes timeout in milliseconds before the fallback is treated as unavailable
ROUTING_GOOGLE_ROUTES_TIMEOUT_MS=3500

# App Configuration
NODE_ENV=development

# Secret for the Vercel Cron sweep (GET /api/admin/sweep/stale-trips).
# Set the same value in Vercel project env vars; Vercel sends it as
# `Authorization: Bearer <CRON_SECRET>` on scheduled runs. If unset, the cron
# endpoint returns 401 (admin POST sweep still works).
CRON_SECRET=your-cron-secret-here

# Email Service Configuration (for OTP Password Reset)
# Provider priority: BREVO_API_KEY > RESEND_API_KEY > dev console.
#
# Brevo (recommended free option — 300 emails/day, no domain needed):
#   1. Sign up free at https://www.brevo.com
#   2. Settings > Senders & IP > add and VERIFY a sender email (your Gmail works)
#   3. Settings > SMTP & API > API Keys > create a key (starts with "xkeysib-")
#   4. Set BREVO_API_KEY below and EMAIL_FROM to the verified sender.
BREVO_API_KEY=your_brevo_api_key_here

# Resend (alternative — requires a verified DOMAIN for production)
# Sign up at: https://resend.com (Free tier: 3,000 emails/month)
RESEND_API_KEY=your_resend_api_key_here

# Email sender address. Must be a Brevo-verified sender (or Resend-verified domain).
# Format with display name: "Basey FareCheck <noreply@yourdomain.com>"
# onboarding@resend.dev only works in dev-console mode, never in production.
EMAIL_FROM=Basey FareCheck <your_verified_sender@example.com>

# Note: If no provider key is set (dev only), OTP codes are logged to the server console.
