{
  "expo": {
    "name": "Basey FareCheck",
    "slug": "basey-farecheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "baseyfare",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.basey.farecheck"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.basey.farecheck",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Basey FareCheck to use your location to calculate fares."
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Basey FareCheck to access your photos for discount card applications.",
          "cameraPermission": "Allow Basey FareCheck to use your camera for discount card ID photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
