# Database
DATABASE_URL="your_neon_database_connection_string_here"

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# JWT Secret for authentication
JWT_SECRET="your-jwt-secret-key-here"

# Google Maps API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Replace YOUR_NEW_GOOGLE_MAPS_API_KEY with your actual new API key
# DO NOT commit API keys to version control
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_NEW_GOOGLE_MAPS_API_KEY

# Google Maps API Key for server-side geocoding operations
GOOGLE_MAPS_SERVER_API_KEY=YOUR_NEW_GOOGLE_MAPS_API_KEY

# Dedicated Google Routes key for server-side planner fallback (recommended)
# This key should be allowed to call routes.googleapis.com without HTTP referrer restrictions.
GOOGLE_ROUTES_API_KEY=YOUR_GOOGLE_ROUTES_SERVER_API_KEY

# Routing timeouts in milliseconds
ROUTING_ORS_TIMEOUT_MS=3500
ROUTING_GOOGLE_ROUTES_TIMEOUT_MS=3500

# App Configuration
NODE_ENV=development

# Vercel Blob read/write token for evidence uploads
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token_here